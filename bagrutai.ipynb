  {
   "cell_type": "code",
   "id": "6q1tuorcxk",
   "source": "%pip install gradio -q\n\nimport gradio as gr\nimport torch\nimport os\nfrom peft import PeftModel\nfrom unsloth import FastLanguageModel\n\n# --- Load model (reuses if already in memory) ---\nBASE_MODEL_NAME = \"unsloth/gemma-2-2b-it-bnb-4bit\"\nADAPTER_DIR = \"outputs/lora_adapter\"\n\nif \"ft_model\" not in dir() or ft_model is None:\n    print(\"⏳ Loading model...\")\n    base_model, base_tokenizer = FastLanguageModel.from_pretrained(\n        model_name=BASE_MODEL_NAME, max_seq_length=2048, dtype=None, load_in_4bit=True,\n    )\n    ft_model = PeftModel.from_pretrained(base_model, ADAPTER_DIR)\n    ft_model = FastLanguageModel.for_inference(ft_model)\n    tokenizer = base_tokenizer\n    print(\"✅ Model loaded!\")\n\nSYSTEM_PROMPT = \"אתה מורה עזר לאזרחות שמכין תלמידים לבגרות בישראל.\"\n\ndef chat_fn(message, history):\n    user_input = f\"{SYSTEM_PROMPT}\\n\\n{message}\"\n    prompt = tokenizer.apply_chat_template(\n        [{\"role\": \"user\", \"content\": user_input}],\n        tokenize=False,\n        add_generation_prompt=True,\n    )\n    device = \"cuda\" if torch.cuda.is_available() else \"cpu\"\n    inputs = tokenizer(prompt, return_tensors=\"pt\").to(device)\n\n    with torch.no_grad():\n        out = ft_model.generate(\n            **inputs,\n            max_new_tokens=300,\n            do_sample=False,\n        )\n    answer_tokens = out[0][inputs[\"input_ids\"].shape[-1]:]\n    return tokenizer.decode(answer_tokens, skip_special_tokens=True).strip()\n\n# --- Custom CSS for Hebrew RTL + polished look ---\ncustom_css = \"\"\"\n/* RTL for the whole app */\n.gradio-container { direction: rtl !important; }\n\n/* Chat bubbles */\n.message { direction: rtl !important; text-align: right !important; font-size: 16px !important; line-height: 1.8 !important; }\n\n/* Input box */\ntextarea { direction: rtl !important; text-align: right !important; font-size: 16px !important; }\n\n/* Header */\n.gr-header { text-align: center !important; }\n\n/* Nice gradient header */\n#component-0 { background: linear-gradient(135deg, #667eea 0%, #764ba2 100%) !important;\n               border-radius: 12px !important; padding: 20px !important; margin-bottom: 16px !important; }\n\"\"\"\n\n# --- Build the interface ---\nwith gr.Blocks(\n    theme=gr.themes.Soft(primary_hue=\"indigo\", secondary_hue=\"purple\"),\n    css=custom_css,\n    title=\"BagrutAI — מורה עזר לאזרחות\",\n) as demo:\n\n    gr.HTML(\"\"\"\n    <div style=\"text-align:center; padding: 24px 16px; background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);\n                border-radius: 16px; margin-bottom: 20px; color: white;\">\n        <h1 style=\"margin:0; font-size:2.2em;\">🎓 BagrutAI</h1>\n        <p style=\"margin:8px 0 0 0; font-size:1.1em; opacity:0.9;\">מורה עזר חכם לאזרחות — הכנה לבגרות בישראל</p>\n    </div>\n    \"\"\")\n\n    chatbot = gr.ChatInterface(\n        fn=chat_fn,\n        chatbot=gr.Chatbot(\n            height=480,\n            placeholder=\"<div style='text-align:center; color:#888; padding:40px;'>שאל אותי שאלה מבחינת הבגרות באזרחות 📚</div>\",\n            rtl=True,\n        ),\n        textbox=gr.Textbox(\n            placeholder=\"...כתוב שאלה באזרחות\",\n            rtl=True,\n            scale=7,\n        ),\n        submit_btn=\"שלח\",\n        retry_btn=\"נסה שוב\",\n        undo_btn=\"בטל\",\n        clear_btn=\"נקה הכל\",\n        examples=[\n            \"הציגו את עיקרי חוק השבות.\",\n            \"הציגו את המושג ביקורת שיפוטית.\",\n            \"הציגו את המושג דמוקרטיה מתגוננת.\",\n            \"הציגו את עיקרי הסדר הסטטוס־קוו.\",\n            \"מהם התנאים ההכרחיים לקיום בחירות דמוקרטיות?\",\n        ],\n        cache_examples=False,\n    )\n\n    gr.HTML(\"\"\"\n    <div style=\"text-align:center; padding:12px; color:#888; font-size:0.85em; border-top:1px solid #eee; margin-top:16px;\">\n        BagrutAI — פרויקט גמר בית ספרי | מבוסס על Gemma 2 2B + LoRA<br>\n        ⚠️ המודל עלול לטעות — יש להשתמש ככלי עזר ללמידה בלבד\n    </div>\n    \"\"\")\n\ndemo.launch(share=True, debug=False)",
